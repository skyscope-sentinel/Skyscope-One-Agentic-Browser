{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "composite": true,
    "incremental": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@skyscope/*": ["packages/*/src"]
    }
  },
  "references": [
    { "path": "packages/agent-core" },
    { "path": "packages/models" },
    { "path": "packages/automation" },
    { "path": "packages/oauth" }
  ],
  "exclude": [
    "node_modules",
    "dist",
    "out",
    "**/node_modules/*"
  ]
}
